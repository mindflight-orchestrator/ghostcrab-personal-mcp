# Copy to .env in this folder, then run: npm install && npm run setup
# MindBrain must be running and reachable (start from your app: gcp brain up).

NODE_ENV=development
GHOSTCRAB_MINDBRAIN_URL=http://127.0.0.1:8091

# Optional: align with your SQLite layout if the backend uses a custom path
# GHOSTCRAB_SQLITE_PATH=data/ghostcrab.sqlite

# Private registry pulls (schemas / skills from demo-manifest.json)
# Configure once on the machine:
#   gcp env set registry.token <your-token>
#   gcp env set registry.url https://registry.ghostcrab.io

# GhostCrab SQLite — MindBrain-backed SQLite deployment
# Copy to .env and adjust before starting.

NODE_ENV=development

# ── Backend (ghostcrab-backend / Zig) ───────────────────────────────────────
# The Zig backend listens on this address and owns the SQLite file.
GHOSTCRAB_BACKEND_ADDR=:8091
GHOSTCRAB_SQLITE_PATH=data/ghostcrab.sqlite

# ── MCP server (Node.js) ────────────────────────────────────────────────────
# Points to the ghostcrab-backend HTTP server started above.
GHOSTCRAB_MINDBRAIN_URL=http://127.0.0.1:8091

# Optional: path to ghostcrab-document when not using the bundled platform binary.
# GHOSTCRAB_DOCUMENT_ENGINE=/absolute/path/to/ghostcrab-document

# ── Embeddings ───────────────────────────────────────────────────────────────
# disabled: BM25-only retrieval (no vectors). Change to openrouter for full hybrid search.
GHOSTCRAB_EMBEDDINGS_MODE=disabled
GHOSTCRAB_EMBEDDING_DIMENSIONS=1536
GHOSTCRAB_EMBEDDINGS_MODEL=openai/text-embedding-3-small
GHOSTCRAB_EMBEDDINGS_API_KEY=
GHOSTCRAB_EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
GHOSTCRAB_EMBEDDINGS_TIMEOUT_MS=30000
GHOSTCRAB_EMBEDDINGS_FIXTURE_PATH=

# ── Retrieval weights ────────────────────────────────────────────────────────
GHOSTCRAB_HYBRID_BM25_WEIGHT=0.6
GHOSTCRAB_HYBRID_VECTOR_WEIGHT=0.4

# ── Misc ─────────────────────────────────────────────────────────────────────
# Quieter npm postinstall (still warns if the platform prebuild is missing).
# GHOSTCRAB_POSTINSTALL_QUIET=1
# Skip copying .env / data/ / doc symlinks into the consuming project (local npm install only).
# GHOSTCRAB_SKIP_HOST_BOOTSTRAP=1
# Skip gcp + backend --help checks after install (not recommended).
# GHOSTCRAB_SKIP_POSTINSTALL_SMOKE=1
GHOSTCRAB_CONFIG_PATH=
GHOSTCRAB_ENV_PATH=
MINDBRAIN_NATIVE_EXTENSIONS=sql-only

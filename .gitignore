# macOS
.DS_Store

# Node / TypeScript
.env
.env.local
.env.*.local
coverage/
dist/
dist-pack/
node_modules/
*.tsbuildinfo

# Zig build artifacts
.zig-cache/
.zig-cache-cross/
zig-out/
cmd/backend/zig-out*/
cmd/backend/.zig-cache*/

# sqlite3 amalgamation (downloaded at build time, not committed)
cmd/backend/deps/sqlite3/sqlite3.c
cmd/backend/deps/sqlite3/sqlite3.h

# Registry tokens (never commit real tokens)
cmd/registry/tokens.json

# Go build artifacts
cmd/registry/registry

# Pre-compiled backend binaries (generated by CI / local Zig — never commit into git).
# Publish workflow downloads these from CI artifacts before npm publish.
# Ignore everything under prebuilds/ except the placeholder so the directory exists for clones.
prebuilds/*
!prebuilds/.gitkeep

# Platform npm packs (@mindflight/ghostcrab-personal-mcp-*): commit package.json only.
# Binaries under bin/, Licence.md copies, and any other staging outputs come from prebuilds/ via scripts.
packages/prebuild-*/*
!packages/prebuild-*/package.json

# Vendored PostgreSQL install (from build-macos.sh)
.pg_install/

# Editor / IDE — never commit local agent configs (skills ship under ghostcrab-skills/)
.codex
.codex/

data/
doc_ext/
docs/dev/
logs/
*.log

.cursor/
.claude/
.claude.md
CLAUDE.md

vendor/*
!vendor/mindbrain